// ============================================================
// chiro-saas — Prisma Schema
// ルール: 全テーブルに tenant_id を必ず付与すること。
//         クエリ時は必ず tenant_id でフィルタリングすること。
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Prisma 7: 接続URLは prisma.config.ts で管理する（schema.prismaには記述不要）
datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum TenantPlan {
  standard
  pro
}

/// Profile のロール。super_admin は Supabase の別テーブルで管理する。
enum UserRole {
  admin  // tenant_admin 相当
  staff
}

enum AppointmentStatus {
  pending    // 仮受付（初期状態）
  confirmed  // 確定（承認済）
  cancelled  // キャンセル
  rejected   // お断り（院都合で受付不可）
  no_show    // 無断欠席
  completed  // 施術完了
}

/// カルテのモード。記録時点のスナップショットとして保持する。
enum KarteMode {
  simple       // B院デフォルト: 症状テキスト・経過メモのみ
  professional // A院: 部位選択・写真・動画・施術内容を含む
}

enum ConditionStatus {
  good   // 良好
  fair   // 普通
  pain   // 痛い
  severe // 強い痛み
}

enum MediaType {
  image
  video
}

/// カルテの種別。MEDICAL=施術記録、TRAINING=トレーニング記録。
enum KarteType {
  MEDICAL   // 施術カルテ（デフォルト）
  TRAINING  // トレーニングカルテ
}

enum NotificationChannel {
  line
  email
}

/// CLAUDE.md 規約: デフォルトのリマインダー送信タイミングは 24h前 と 2h前
enum NotificationType {
  confirmation  // 予約確定通知
  reminder_24h  // リマインダー (24時間前)
  reminder_2h   // リマインダー (2時間前)
  cancellation  // キャンセル通知
  rejection     // お断り通知（院都合）
}

enum NotificationStatus {
  pending  // 送信待ち
  sent     // 送信済み
  failed   // 送信失敗
}

// ============================================================
// 1. テナント基盤
// ============================================================

/// 整骨院（テナント）の基本情報。全テーブルの親となる。
model Tenant {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar(255)
  subdomain   String?    @unique @db.VarChar(64)
  logoUrl     String?    @map("logo_url")
  colorTheme  Json?      @map("color_theme") // {"primary": "#3B82F6", "accent": "#10B981"}
  plan        TenantPlan @default(standard)
  phone                  String?    @db.VarChar(20)
  address                String?    @db.VarChar(255)
  lineChannelSecret      String?    @map("line_channel_secret")
  lineChannelAccessToken String?    @map("line_channel_access_token")
  lineFriendUrl          String?    @map("line_friend_url")
  lineEnabled            Boolean    @default(true)  @map("line_enabled")
  emailEnabled           Boolean    @default(false) @map("email_enabled")
  emailCustomMessage     String?    @map("email_custom_message") // 旧フィールド（移行済み後は未使用）
  /// 通知種別ごとのカスタムメッセージ（プロプラン限定）
  emailConfirmMsg   String?  @map("email_confirm_msg")   // メール×予約確定
  emailChangeMsg    String?  @map("email_change_msg")    // メール×予約変更
  emailReminderMsg  String?  @map("email_reminder_msg")  // メール×リマインド
  lineConfirmMsg    String?  @map("line_confirm_msg")    // LINE×予約確定
  lineChangeMsg     String?  @map("line_change_msg")     // LINE×予約変更
  lineReminderMsg   String?  @map("line_reminder_msg")   // LINE×リマインド
  emailReceiveMsg   String?  @map("email_receive_msg")   // メール×予約受付
  lineReceiveMsg    String?  @map("line_receive_msg")    // LINE×予約受付
  emailRejectMsg    String?  @map("email_reject_msg")    // メール×お断り
  lineRejectMsg     String?  @map("line_reject_msg")     // LINE×お断り
  isActive           Boolean    @default(true) @map("is_active")
  businessStartTime  String     @default("09:00") @map("business_start_time") @db.VarChar(5)
  businessEndTime    String     @default("20:00") @map("business_end_time")   @db.VarChar(5)
  regularHolidays    Int[]      @default([0]) @map("regular_holidays")
  lunchStartTime     String?    @map("lunch_start_time") @db.VarChar(5)
  lunchEndTime       String?    @map("lunch_end_time")   @db.VarChar(5)
  /// 予約グリッドの刻み分数。選択肢: 15 | 20 | 30 | 60
  slotInterval       Int        @default(30) @map("slot_interval")
  /// 同一時間帯に受け入れ可能な最大予約数（1 = 同時1人まで）
  maxCapacity        Int        @default(1)  @map("max_capacity")
  /// トレーニング体組成指標の表示設定 JSON: { weight, bodyFat, bmi, muscleMass, bmr, visceralFat }
  trainingMetricsConfig Json?   @map("training_metrics_config")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user               User?
  settings           TenantSetting[]
  businessHours      BusinessHour[]
  profiles           Profile[]
  staffs             Staff[]
  patients           Patient[]
  appointments       Appointment[]
  kartes             Karte[]
  exerciseCategories ExerciseCategory[]
  exercises          Exercise[]
  services           Service[]
  notificationQueue  NotificationQueue[]

  @@map("tenants")
}

/// 認証ユーザー（テナント管理者）。bcrypt でパスワードハッシュ化して保存。
/// CLAUDE.md 規約: 1テナントにつき 1ユーザーが基本（スタッフ追加は Phase 2）
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @unique @map("tenant_id") @db.Uuid
  loginId   String   @unique @map("login_id") @db.VarChar(64)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255) // bcrypt ハッシュ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

/// SaaS 運営者（システム管理者）アカウント。テナントに属さない特権ユーザー。
/// `/admin` 配下のページにのみアクセスできる。
model SuperAdmin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255) // bcrypt ハッシュ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("super_admins")
}

/// パスワード再設定トークン。有効期限 1時間。
model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expires   DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([email])
  @@map("password_reset_tokens")
}

/// フィーチャートグル設定テーブル。
/// テナントごとに karte_mode, training_record 等のキーと値を保持する。
/// CLAUDE.md 規約: TenantFeatureService を介して参照すること。直接クエリ禁止。
model TenantSetting {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  featureKey   String   @map("feature_key") @db.VarChar(64)
  featureValue String   @map("feature_value") // 'true' | 'false' | 数値文字列 | enum文字列
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@map("tenant_settings")
}

// ============================================================
// 2. 認証・ユーザー（スタッフ / 管理者）
// ============================================================

/// Supabase Auth (auth.users) と紐付くスタッフ・管理者プロフィール。
/// id は Supabase Auth の UUID をそのまま使用する。
/// CLAUDE.md 規約: 認証は Supabase Auth のセッション管理を利用すること。
model Profile {
  id          String   @id @db.Uuid // = supabase auth.users.id
  tenantId    String   @map("tenant_id") @db.Uuid
  email       String   @db.VarChar(255)
  displayName String   @map("display_name") @db.VarChar(255)
  role        UserRole
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 予約との関連
  confirmedAppointments Appointment[]   @relation("ConfirmedByProfile")
  cancelledAppointments Appointment[]   @relation("CancelledByProfile")
  appointmentLogs      AppointmentLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("profiles")
}

/// スタッフ情報。予約の担当者として割り当てるためのマスターデータ。
/// Profile（ログインユーザーアカウント）とは別に管理する。
model Staff {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  role      String?  @db.VarChar(255) // 役職/肩書き
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  kartes       Karte[]

  @@index([tenantId])
  @@map("staffs")
}

// ============================================================
// 3. 業務コア
// ============================================================

/// 患者情報。LINE連携用の line_user_id を保持する。
model Patient {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  displayName      String    @map("display_name") @db.VarChar(255)
  nameKana         String?   @map("name_kana") @db.VarChar(255)   // ふりがな（ひらがな）
  email            String?   @db.VarChar(255)
  phone            String?   @db.VarChar(20)
  birthDate        DateTime? @map("birth_date") @db.Date
  lineUserId       String?   @unique @map("line_user_id") @db.VarChar(64) // LINE ユーザーID
  accessToken            String?   @unique @map("access_token") @db.Uuid          // マイページ用マジックリンクトークン
  accessPin              String?   @map("access_pin") @db.VarChar(72)              // bcrypt ハッシュ（旧: 4桁平文, 移行サポートあり）
  pinResetToken          String?   @unique @map("pin_reset_token") @db.VarChar(64) // 暗証番号再設定ワンタイムトークン
  pinResetTokenExpiresAt DateTime? @map("pin_reset_token_expires_at") @db.Timestamptz // 再設定トークンの有効期限（24h）
  emergencyContact       String?   @map("emergency_contact") @db.VarChar(255)
  heightCm         Float?    @map("height_cm")  // 身長 (cm): BMI 自動計算に使用
  memo             String?   // 院内メモ（患者非表示）
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  kartes            Karte[]
  notificationQueue NotificationQueue[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, lineUserId])
  @@map("patients")
}

/// 予約情報。
/// CLAUDE.md 規約:
///   - ステータスは必ず pending → confirmed の順を経ること
///   - ステータス変更は必ず AppointmentLog に記録すること
///   - require_approval トグルは全テナント必須（OFF不可）
model Appointment {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  patientId   String            @map("patient_id") @db.Uuid
  staffId     String?           @map("staff_id") @db.Uuid // NULL = スタッフ指名なし (staff_assignment=false 時)
  menuName    String            @map("menu_name") @db.VarChar(255) // 施術メニュー名（スナップショット）
  durationMin Int               @map("duration_min") // 所要時間（分）
  price       Int               // 料金（円）
  status      AppointmentStatus @default(pending)
  startAt     DateTime          @map("start_at") @db.Timestamptz
  endAt       DateTime          @map("end_at") @db.Timestamptz
  note        String?           // 患者からの備考

  // 承認情報
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamptz
  confirmedBy String?   @map("confirmed_by") @db.Uuid

  // キャンセル情報
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledBy String?   @map("cancelled_by") @db.Uuid

  // リマインダー送信済みフラグ（二重送信防止）
  reminderSent Boolean @default(false) @map("reminder_sent")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient         Patient            @relation(fields: [patientId], references: [id])
  staff           Staff?             @relation(fields: [staffId], references: [id])
  confirmedByUser Profile?           @relation("ConfirmedByProfile", fields: [confirmedBy], references: [id])
  cancelledByUser Profile?           @relation("CancelledByProfile", fields: [cancelledBy], references: [id])
  logs            AppointmentLog[]
  karte           Karte?
  notificationQueue NotificationQueue[]

  @@index([tenantId, startAt])
  @@index([tenantId, patientId])
  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@map("appointments")
}

/// 予約ステータス変更履歴。
/// CLAUDE.md 規約: ステータス変更時は必ずこのテーブルに記録すること（絶対ルール）。
model AppointmentLog {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String            @map("appointment_id") @db.Uuid
  oldStatus     AppointmentStatus @map("old_status")
  newStatus     AppointmentStatus @map("new_status")
  changedById   String            @map("changed_by_id") @db.Uuid
  note          String?           // 変更理由など
  changedAt     DateTime          @default(now()) @map("changed_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedBy   Profile     @relation(fields: [changedById], references: [id])

  @@index([appointmentId])
  @@map("appointment_logs")
}

/// 施術記録（カルテ）。
/// simple モード: conditionNote, progressNote のみ使用。
/// professional モード (A院): 上記 + bodyParts, treatments, conditionStatus, KarteMedia を使用。
/// CLAUDE.md 規約: karteModeSnapshot で記録時点のモードを保持すること（設定変更後も参照可能）。
model Karte {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  appointmentId       String?        @unique @map("appointment_id") @db.Uuid
  patientId           String         @map("patient_id") @db.Uuid
  staffId             String?        @map("staff_id") @db.Uuid
  karteModeSnapshot   KarteMode      @map("karte_mode_snapshot") // 記録時点のモードを固定保存
  karteType           KarteType      @default(MEDICAL) @map("karte_type") // MEDICAL=施術, TRAINING=トレーニング

  // simple / professional 共通
  conditionNote       String?        @map("condition_note")   // 症状メモ
  progressNote        String?        @map("progress_note")    // 経過メモ

  // professional モードのみ使用
  conditionStatus     ConditionStatus? @map("condition_status") // 状態評価
  bodyParts           String[]       @map("body_parts")       // 部位選択（例: ["腰", "首"]）
  treatments          String[]       // 施術内容（例: ["アクチベーター", "指圧"]）

  // 体組成データ（training_record ON の場合、トレーニングカルテで使用）
  weight      Float?   @map("weight")       // 体重 (kg)
  bodyFat     Float?   @map("body_fat")     // 体脂肪率 (%)
  bmi         Float?   @map("bmi")          // BMI
  muscleMass  Float?   @map("muscle_mass")  // 筋肉量 (kg)
  bmr         Float?   @map("bmr")          // 基礎代謝 (kcal)
  visceralFat Float?   @map("visceral_fat") // 内臓脂肪レベル

  // 動的な体組成指標の保存先 (JSON: { "metricId": value })
  bodyCompValues Json? @map("body_comp_values")

  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  patient     Patient      @relation(fields: [patientId], references: [id])
  staff       Staff?       @relation(fields: [staffId], references: [id])

  // professional モードのみ利用する子テーブル
  media           KarteMedia[]
  exerciseRecords ExerciseRecord[]

  @@index([tenantId, patientId])
  @@index([tenantId, appointmentId])
  @@map("kartes")
}

/// カルテ添付ファイル（写真・動画）。professional モードのみ使用。
/// CLAUDE.md 規約:
///   - ストレージは Supabase Storage + RLS を使用すること
///   - fileUrl には署名付きURL（Signed URL）を生成して返すこと（公開URLは禁止）
///   - 1ファイル最大 50MB のバリデーションを実装すること
model KarteMedia {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  karteId     String    @map("karte_id") @db.Uuid
  storagePath String    @map("storage_path")         // Supabase Storage 上のパス（Signed URL生成に使用）
  mediaType   MediaType @map("media_type")
  fileSizeKb  Int?      @map("file_size_kb")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  karte Karte @relation(fields: [karteId], references: [id], onDelete: Cascade)

  @@index([karteId])
  @@map("karte_media")
}

/// トレーニングカテゴリマスタ。ExerciseCategory を DB で管理し、ハードコードを排除する。
model ExerciseCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(64)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([tenantId])
  @@map("exercise_categories")
}

/// トレーニング種目マスタ。training_record トグルが有効な場合（A院）に使用。
/// CLAUDE.md 規約: 一般的な種目をプリセットし、管理画面から tenant_admin が CRUD 操作可能とする。
model Exercise {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  categoryId String?  @map("category_id") @db.Uuid // ExerciseCategory への FK（任意）
  name       String   @db.VarChar(255) // 種目名（例: "スクワット"）
  category   String?  @db.VarChar(64)  // カテゴリ名スナップショット（既存互換性のため残す）
  unit        String?  @db.VarChar(32)  // 単位（例: "kg", "回", "秒"）
  duration    Int      @default(0)      // 所要時間（分）: お客様の滞在時間
  intervalMin Int      @default(0) @map("interval_min") // 次予約までの準備時間（分）
  price       Int      @default(0)      // 料金（円）
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exerciseCategory ExerciseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  records          ExerciseRecord[]

  @@index([tenantId])
  @@map("exercises")
}

/// トレーニング実施記録。Karte に紐付く。
model ExerciseRecord {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  karteId    String   @map("karte_id") @db.Uuid
  exerciseId String   @map("exercise_id") @db.Uuid
  sets       Int?
  reps       Int?
  weightKg   Decimal? @map("weight_kg") @db.Decimal(5, 2)
  durationSec Int?    @map("duration_sec")
  memo       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  karte    Karte    @relation(fields: [karteId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([tenantId, karteId])
  @@map("exercise_records")
}

// ============================================================
// 4. 通知管理
// ============================================================

/// LINE / メール通知の送信キュー。
/// CLAUDE.md 規約:
///   - デフォルトのリマインダー送信タイミングは 予約24時間前 と 2時間前
///   - 送信チャネルは LINE Messaging API を使用する
model NotificationQueue {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  appointmentId    String             @map("appointment_id") @db.Uuid
  patientId        String             @map("patient_id") @db.Uuid
  channel          NotificationChannel
  notificationType NotificationType   @map("notification_type")
  scheduledAt      DateTime           @map("scheduled_at") @db.Timestamptz // 送信予定日時
  status           NotificationStatus @default(pending)
  sentAt           DateTime?          @map("sent_at") @db.Timestamptz
  errorMessage     String?            @map("error_message")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@index([tenantId, scheduledAt, status]) // バッチ処理での未送信キュー取得用
  @@index([appointmentId])
  @@map("notification_queue")
}

// ============================================================
// 5. 施術マスタ
// ============================================================

/// 施術メニューマスタ。予約作成ダイアログや患者向けフォームで選択肢として使用する。
/// CLAUDE.md 規約: tenantId で論理分離。直接 DB クエリ時は必ず tenantId フィルタを含めること。
model Service {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)  // 施術名（例: "整体コース"）
  duration    Int                         // 所要時間（分）: お客様の滞在時間
  intervalMin Int      @default(0) @map("interval_min") // 次予約までの準備時間（分）
  price       Int                         // 料金（円）
  description String?                     // 施術の説明
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt       @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("services")
}

// ============================================================
// 6. 曜日別営業時間
// ============================================================

/// 曜日ごとの営業時間設定。
/// dayOfWeek は JS の getDay() と同じ: 0=日, 1=月, ..., 6=土
model BusinessHour {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  dayOfWeek Int     @map("day_of_week")
  isOpen    Boolean @default(true)  @map("is_open")
  openTime  String  @default("09:00") @map("open_time")  @db.VarChar(5)
  closeTime String  @default("20:00") @map("close_time") @db.VarChar(5)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
  @@map("business_hours")
}
